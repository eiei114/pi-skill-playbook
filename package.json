{
  "name": "pi-skill-playbook",
  "version": "0.1.5",
  "type": "module",
  "description": "Pi extension for passive, human-mediated Agent Skill playbooks.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "agent-skills",
    "playbook"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-skill-playbook.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-skill-playbook/issues"
  },
  "homepage": "https://github.com/eiei114/pi-skill-playbook#readme",
  "license": "MIT",
  "files": [
    "extensions/",
    "src/",
    "samples/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts",
    "build": "npm run check",
    "validate:package": "npm pack --dry-run",
    "version:check": "node scripts/check-version-bump.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
